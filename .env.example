PORT=3001
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# development: json mode returns success and prints generated emails in server logs.
# production: use MAIL_MODE=smtp and fill SMTP values.
MAIL_MODE=json
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=login@example.com
SMTP_PASS=app-password
FROM_EMAIL="Amin Portfolio <login@example.com>"
OWNER_EMAIL=owner@example.com

# Optional AI helper. If the key is absent, the API returns a local fallback summary.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
